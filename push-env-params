#!/usr/bin/env bash

# How to use:
# ./push-env-params development
# ./push-env-params production

set -euo pipefail

APP_ENVIRONMENT="${1:?First argument must be environment: development or production}"
APP_NAME="wedigbio-reports"
ENV_FILE=".env.aws.${APP_ENVIRONMENT}"
SSM_PREFIX="/${APP_NAME}/${APP_ENVIRONMENT}"

if [ ! -f "$ENV_FILE" ]; then
    echo "Error: File $ENV_FILE not found."
    exit 1
fi

echo "Pushing parameters from $ENV_FILE to SSM path $SSM_PREFIX using default profile..."

# Read file line by line
while IFS= read -r line || [ -n "$line" ]; do
    # 1. Strip Carriage Returns (\r) immediately (crucial for Windows-edited files)
    line=$(echo "$line" | tr -d '\r')

    # 2. Skip comments and empty lines
    [[ "$line" =~ ^#.*$ ]] && continue
    [[ -z "${line// /}" ]] && continue

    # 3. Skip lines without an equals sign
    if [[ "$line" != *"="* ]]; then
        continue
    fi

    # 4. Extract key and value (using cut to handle the first = only)
    key=$(echo "$line" | cut -d '=' -f 1 | xargs)
    value=$(echo "$line" | cut -d '=' -f 2-)

    # 5. Trim leading/trailing whitespace from value without interpreted xargs
    value="${value#"${value%%[![:space:]]*}"}"
    value="${value%"${value##*[![:space:]]}"}"

    # 6. Remove surrounding quotes from value
    value=$(echo "$value" | sed -e 's/^"//' -e 's/"$//' -e "s/^'//" -e "s/'$//")

    # 7. Ensure value is not empty (AWS SSM requirement)
    if [ -z "$value" ]; then
        echo "⚠️  Skipping ${key}: AWS SSM requires values to be at least 1 character long."
        continue
    fi

    echo "Pushing ${SSM_PREFIX}/${key}..."

    aws ssm put-parameter \
      --region us-east-2 \
      --name "${SSM_PREFIX}/${key}" \
      --value "$value" \
      --type "SecureString" \
      --overwrite > /dev/null

done < "$ENV_FILE"

echo "✅ All parameters pushed successfully!"
